{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "expense-tracker-ai",
  "main": "src/index.ts",
  "compatibility_date": "2024-11-01",
  "compatibility_flags": ["nodejs_compat"],

  // Observability — logs on with invocation logs, traces off.
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true,
    },
    "traces": {
      "enabled": true,
    },
  },

  // Non-secret config only. Secrets live in `.dev.vars` for local development
  // and must be uploaded to production via `npx wrangler secret put <NAME>`.
  // See the README for the full list of required secrets.
  "vars": {
    "SUPABASE_URL": "https://ydpvxgjfcftaipcpirph.supabase.co",
    "SUPABASE_ANON_KEY": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InlkcHZ4Z2pmY2Z0YWlwY3BpcnBoIiwicm9sZSI6ImFub24iLCJpYXQiOjE3MzE4MjE1MzYsImV4cCI6MjA0NzM5NzUzNn0.yuxmXqf3CmdscasibvJcMKEyFneflhIXvD7FgSOHeoo",
    "ALLOWED_ORIGIN": "",
    "AI_PROVIDER": "gemini",
    "WHATSAPP_TEMPLATE_NAME": "expense_tracker_verify",

    // LangSmith tracing. Set to "true" to enable; the LANGSMITH_API_KEY secret
    // must also be set (`wrangler secret put LANGSMITH_API_KEY`). For non-US
    // regions also set LANGSMITH_ENDPOINT (e.g. https://eu.api.smith.langchain.com).
    "LANGSMITH_TRACING": "true",
    "LANGSMITH_PROJECT": "expense-tracker",
  },
}
